# KHOps Configuration

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=True
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://khops:khops_dev@localhost:5432/khops
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# Storage Configuration
STORAGE_TYPE=local
STORAGE_PATH=./data/artifacts
# S3 Configuration (if needed)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=khops-artifacts

# Registry Configuration
REGISTRY_PATH=./data/registry
MODEL_REGISTRY_PATH=./data/models

# Observability
OBSERVABILITY_ENABLED=True
METRICS_ENABLED=True
TRACES_ENABLED=False
LOGS_ENABLED=True

# Loki Configuration (Optional)
LOKI_URL=http://localhost:3100
LOKI_LABEL_JOB=khops

# Prometheus Configuration (Optional)
PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=9090

# Authentication (Future)
AUTH_ENABLED=False
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler Configuration
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC
SCHEDULER_POOL_SIZE=5

# Execution Configuration
EXECUTION_TIMEOUT_SECONDS=3600
EXECUTION_MAX_RETRIES=3
EXECUTION_RETRY_DELAY_SECONDS=10

# Email Configuration (Future)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@khops.local

# Sentry Configuration (Optional)
SENTRY_DSN=

# Pipeline Configuration
PIPELINE_MAX_PARALLEL_NODES=5
PIPELINE_TIMEOUT_SECONDS=3600

# Logging Configuration
LOG_FORMAT=json
LOG_TO_FILE=True
LOG_FILE_PATH=./logs/khops.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
