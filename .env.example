# Development Environment Template
# Copy to .env and customize for your environment
# NEVER commit .env with real credentials!

# Environment Selection (dev, prod, or default)
ENVIRONMENT=dev

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
MODEL_SERVER_HOST=127.0.0.1
MODEL_SERVER_PORT=8001

# Debug and Logging
DEBUG=true
LOG_LEVEL=DEBUG
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/khops_dev.log

# Database Configuration
# Local PostgreSQL: postgresql://khops:khops_dev@localhost:5432/khops_dev
# SQLite (testing): sqlite:///./khops_dev.db
DATABASE_URL=postgresql://khops:khops_dev@localhost:5432/khops_dev
DATABASE_ECHO=true
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5

# Redis Configuration
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=
REDIS_DB=1

# Storage Configuration (local or s3)
STORAGE_TYPE=local
STORAGE_PATH=./data/artifacts_dev

# For S3 Storage:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=khops-dev-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Registry Configuration
REGISTRY_PATH=./data/registry_dev
MODEL_REGISTRY_PATH=./data/models_dev

# Pipeline Configuration
PIPELINE_MAX_PARALLEL_NODES=2
PIPELINE_TIMEOUT_SECONDS=1800
EXECUTION_TIMEOUT_SECONDS=1800
EXECUTION_MAX_RETRIES=1
EXECUTION_RETRY_DELAY_SECONDS=5

# Observability
OBSERVABILITY_ENABLED=true
METRICS_ENABLED=true
TRACES_ENABLED=true
LOGS_ENABLED=true

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_POOL_SIZE=2

# Security (development - not secure!)
AUTH_ENABLED=false
SECRET_KEY=dev-secret-not-secure-change-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
MODEL_REGISTRY_PATH=./data/models

# Observability
OBSERVABILITY_ENABLED=True
METRICS_ENABLED=True
TRACES_ENABLED=False
LOGS_ENABLED=True

# Loki Configuration (Optional)
LOKI_URL=http://localhost:3100
LOKI_LABEL_JOB=khops

# Prometheus Configuration (Optional)
PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=9090

# Authentication (Future)
AUTH_ENABLED=False
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler Configuration
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC
SCHEDULER_POOL_SIZE=5

# Execution Configuration
EXECUTION_TIMEOUT_SECONDS=3600
EXECUTION_MAX_RETRIES=3
EXECUTION_RETRY_DELAY_SECONDS=10

# Email Configuration (Future)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=alerts@khops.local

# Sentry Configuration (Optional)
SENTRY_DSN=

# Pipeline Configuration
PIPELINE_MAX_PARALLEL_NODES=5
PIPELINE_TIMEOUT_SECONDS=3600

# Logging Configuration
LOG_FORMAT=json
LOG_TO_FILE=True
LOG_FILE_PATH=./logs/khops.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
